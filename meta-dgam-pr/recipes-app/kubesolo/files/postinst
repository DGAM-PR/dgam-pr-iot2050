#!/bin/sh

# Create config directory
mkdir -p /var/lib/kubesolo

# Install default config file if it doesn't exist
if [ ! -f /var/lib/kubesolo/config ]; then
    cat > /var/lib/kubesolo/config << 'EOF'
# Kubesolo Configuration
# Uncomment and set these variables for the service to start

# KUBESOLO_PORTAINER_EDGE_ID=your-edge-id-here
# KUBESOLO_PORTAINER_EDGE_KEY=your-base64-key-here

# Optional: enable local storage (upstream default: true, we default to false)
# KUBESOLO_LOCAL_STORAGE=true

# Optional: run SQLite WAL integrity check and repair on startup (default: false)
# Useful after unclean shutdowns caused by power loss
# KUBESOLO_DB_WAL_REPAIR=true

# Optional: disable IPv6 support for CoreDNS and kubelet (default: false)
# KUBESOLO_DISABLE_IPV6=true

# Optional: startup timeout in seconds per component health check (default: 600)
# Increase on slow storage such as SD cards
# KUBESOLO_STARTUP_TIMEOUT=600
EOF
    chmod 600 /var/lib/kubesolo/config
fi

# Enable the service (it won't start until variables are set)
systemctl enable kubesolo.service

echo ""
echo "================================================================"
echo "Kubesolo service has been installed but NOT started."
echo ""
echo "To configure and start the service:"
echo "  1. Edit /var/lib/kubesolo/config"
echo "  2. Set KUBESOLO_PORTAINER_EDGE_ID and KUBESOLO_PORTAINER_EDGE_KEY"
echo "  3. Optionally uncomment and adjust KUBESOLO_LOCAL_STORAGE, KUBESOLO_DB_WAL_REPAIR,"
echo "     KUBESOLO_DISABLE_IPV6, or KUBESOLO_STARTUP_TIMEOUT"
echo "  4. Run: systemctl start kubesolo"
echo ""
echo "The service will retry every 60 seconds if configuration is invalid."
echo "================================================================"
echo ""
