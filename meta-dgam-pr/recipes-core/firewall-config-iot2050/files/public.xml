<?xml version="1.0" encoding="utf-8"?>
<zone>
  <short>Public</short>
  <description>Public zone with MQTT and Node-RED ports open for IOT2050 management access</description>
  <service name="dhcpv6-client"/>
  <service name="ssh"/>
  <service name="mqtt"/>
  <service name="node-red"/>
  <!-- Enable IP masquerading and forwarding so that CNI pod-network traffic
       (kubesolo on the VPN-facing device) can be forwarded and NAT-ed correctly.
       On the PLC-facing device these are harmless: PLC <-> eno2 communication is
       static on both ends within the same 192.168.1.x/24 subnet and never
       requires routing or NAT through the firewall zone. -->
  <masquerade/>
  <forward/>
</zone>
